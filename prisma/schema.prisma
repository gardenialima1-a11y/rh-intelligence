// ============================================================================
// PRISMA SCHEMA — Plataforma de People Analytics & RH BI
// Modelo dimensional: dimensões compartilhadas + tabelas fato por processo
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// AUTENTICAÇÃO E CONTROLE DE ACESSO (RBAC)
// ----------------------------------------------------------------------------

enum Role {
  ADMINISTRADOR
  RH
  DIRETORIA
  GESTOR
  SUPERVISOR
  LIDER
  USUARIO
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(USUARIO)
  unitId        String?
  unit          Unit?     @relation(fields: [unitId], references: [id])
  managerOfId   String?   @unique // vincula este usuário como o "gestor" de dim_gestor, se aplicável
  managerOf     Manager?  @relation("UserManager", fields: [managerOfId], references: [id])
  accounts      Account[]
  sessions      Session[]
  favorites     Favorite[]
  comments      Comment[]
  accessLogs    AccessLog[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AccessLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  path      String
  action    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleKey String
  createdAt DateTime @default(now())

  @@unique([userId, moduleKey])
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  moduleKey  String
  content    String   @db.Text
  createdAt  DateTime @default(now())
}

model Alert {
  id          String   @id @default(cuid())
  moduleKey   String
  title       String
  description String   @db.Text
  severity    Severity @default(ATENCAO)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  @@index([moduleKey, isActive])
}

model Goal {
  id         String   @id @default(cuid())
  moduleKey  String
  indicator  String
  targetValue Float
  comparator  Comparator @default(LTE)
  periodYear  Int
  periodMonth Int?
  createdAt   DateTime @default(now())

  @@unique([moduleKey, indicator, periodYear, periodMonth])
}

enum Severity {
  OK
  ATENCAO
  CRITICO
}

enum Comparator {
  LTE
  GTE
  EQ
}

// ----------------------------------------------------------------------------
// DIMENSÕES COMPARTILHADAS
// ----------------------------------------------------------------------------

model Company {
  id    String @id @default(cuid())
  name  String @unique
  units Unit[]
}

enum UnitType {
  MATRIZ
  FILIAL
}

model Unit {
  id        String   @id @default(cuid())
  name      String
  type      UnitType @default(FILIAL)
  city      String
  state     String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  employees Employee[]
  users     User[]
  vacancies Vacancy[]

  @@unique([companyId, name])
}

model CostCenter {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  area      String
  employees          Employee[] @relation("PrimaryCostCenter")
  secondaryEmployees Employee[] @relation("SecondaryCostCenter")
}

model Position {
  id           String     @id @default(cuid())
  name         String     @unique
  level        String?
  salaryFloor  Float?
  salaryCeil   Float?
  employees    Employee[]
  benchmark    SalaryBenchmark?
  vacancies    Vacancy[]
}

model Manager {
  id           String     @id @default(cuid())
  name         String
  area         String
  level        String?
  reportsToId  String?
  reportsTo    Manager?   @relation("ManagerHierarchy", fields: [reportsToId], references: [id])
  directReports Manager[] @relation("ManagerHierarchy")
  user         User?      @relation("UserManager")
  employees    Employee[]

  @@index([reportsToId])
}

enum ContractType {
  CLT
  PJ
  APRENDIZ
  ESTAGIO
  TEMPORARIO
}

enum Gender {
  MASCULINO
  FEMININO
  NAO_INFORMADO
}

model Employee {
  id             String        @id @default(cuid())
  registration   String        @unique
  name           String
  positionId     String?
  position       Position?     @relation(fields: [positionId], references: [id])
  costCenterId   String?
  costCenter     CostCenter?   @relation("PrimaryCostCenter", fields: [costCenterId], references: [id])
  secondaryCostCenterId String?
  secondaryCostCenter   CostCenter? @relation("SecondaryCostCenter", fields: [secondaryCostCenterId], references: [id])
  managerId      String?
  manager        Manager?      @relation(fields: [managerId], references: [id])
  unitId         String
  unit           Unit          @relation(fields: [unitId], references: [id])
  gender         Gender        @default(NAO_INFORMADO)
  phone          String?
  email          String?
  photoUrl       String?
  birthDate      DateTime?
  admissionDate  DateTime
  terminationDate DateTime?
  contractType   ContractType  @default(CLT)
  contractEndDate DateTime?
  isPCD          Boolean       @default(false)
  isActive       Boolean       @default(true)

  headcountDaily     HeadcountDaily[]
  movements          Movement[]
  timeEntries        TimeEntry[]
  absences           Absence[]
  turnstileEvents    TurnstileEvent[]
  turnstileDailySummaries TurnstileDailySummary[]
  inssLeaves         InssLeave[]
  probationTracking      ProbationTracking?
  trainings          TrainingRecord[]
  reviews            PerformanceReview[]
  safetyIncidents    SafetyIncident[]
  payrolls           PayrollEntry[]
  complianceEvents   ComplianceEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([unitId, isActive])
  @@index([managerId])
  @@index([costCenterId])
}

model Reason {
  id       String @id @default(cuid())
  category String // TURNOVER | AFASTAMENTO | ADVERTENCIA
  label    String

  movements        Movement[]
  absences         Absence[]
  complianceEvents ComplianceEvent[]

  @@unique([category, label])
}

// ----------------------------------------------------------------------------
// TABELAS FATO
// ----------------------------------------------------------------------------

model HeadcountDaily {
  id         String   @id @default(cuid())
  date       DateTime
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  status     String   // ATIVO | AFASTADO | FERIAS

  @@unique([date, employeeId])
  @@index([date])
}

enum MovementType {
  ADMISSAO
  DESLIGAMENTO
  PROMOCAO
  TRANSFERENCIA
}

model Movement {
  id          String       @id @default(cuid())
  date        DateTime
  employeeId  String
  employee    Employee     @relation(fields: [employeeId], references: [id])
  type        MovementType
  reasonId    String?
  reason      Reason?      @relation(fields: [reasonId], references: [id])
  voluntary   Boolean?
  costValue   Float?
  notes       String?      @db.Text

  @@index([date, type])
  @@index([employeeId])
}

model TimeEntry {
  id             String   @id @default(cuid())
  date           DateTime
  employeeId     String
  employee       Employee @relation(fields: [employeeId], references: [id])
  scheduledHours Float
  workedHours    Float
  overtimeHours  Float    @default(0)
  bankHoursDelta Float    @default(0)

  @@unique([date, employeeId])
  @@index([date])
  @@index([employeeId, date])
}

// Afastamento pelo INSS (licença médica de longa duração) — diferente de
// Absence (que é falta pontual, dia a dia). Aqui é um período contínuo, com
// CID, data de início, retorno (quando houver) e observações que vão sendo
// atualizadas ao longo do afastamento.
model InssLeave {
  id                 String    @id @default(cuid())
  employeeId         String
  employee           Employee  @relation(fields: [employeeId], references: [id])
  cid                String
  startDate          DateTime
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  notes              String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([employeeId])
}

model Absence {
  id           String   @id @default(cuid())
  date         DateTime
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  reasonId     String?
  reason       Reason?  @relation(fields: [reasonId], references: [id])
  cid          String?
  hoursLost    Float
  hasCertificate Boolean @default(false)

  @@index([date])
  @@index([employeeId, date])
}

model TurnstileEvent {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  timestamp   DateTime
  direction   String   // ENTRADA | SAIDA
  location    String?

  @@index([employeeId, timestamp])
}

// Resumo diário de tempo fora do posto por colaborador, para importar
// históricos que já vêm agregados por dia (ex.: relatórios anteriores),
// em vez de eventos brutos de entrada/saída. employeeId fica nulo quando
// o nome do relatório não bateu com nenhum colaborador cadastrado — o
// registro ainda fica salvo, só não aparece nos indicadores por colaborador.
model TurnstileDailySummary {
  id           String    @id @default(cuid())
  date         DateTime
  employeeName String
  employeeId   String?
  employee     Employee? @relation(fields: [employeeId], references: [id])
  minutesAway  Int
  accessCount  Int

  @@index([date])
  @@index([employeeId])
}

enum FunnelStage {
  TRIAGEM
  ENTREVISTA_RH
  ENTREVISTA_GESTOR
  TESTE
  PROPOSTA
  CONTRATADO
  REPROVADO
}

model Candidate {
  id            String     @id @default(cuid())
  name          String
  source        String
  vacancy       String
  openedAt      DateTime
  hiredAt       DateTime?
  stage         FunnelStage @default(TRIAGEM)
  isCritical    Boolean    @default(false)
  costToHire    Float?

  @@index([vacancy])
  @@index([stage])
}

enum VacancyStatus {
  ABERTA
  EM_ANDAMENTO
  PREENCHIDA
  CANCELADA
  EM_PAUSA
}

// Cadastro de vagas com status e meta de SLA (dias). Independente da tabela
// Candidate (que já existe e alimenta os indicadores de funil/tempo de
// contratação) — aqui é a gestão da vaga em si, não do candidato.
model Vacancy {
  id          String        @id @default(cuid())
  title       String
  positionId  String?
  position    Position?     @relation(fields: [positionId], references: [id])
  unitId      String?
  unit        Unit?         @relation(fields: [unitId], references: [id])
  status      VacancyStatus @default(ABERTA)
  isCritical  Boolean       @default(false)
  targetDays  Int           @default(30)
  openedAt    DateTime      @default(now())
  closedAt    DateTime?
  notes       String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
}

model TrainingRecord {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  title        String
  hours        Float
  cost         Float    @default(0)
  isMandatory  Boolean  @default(false)
  completedAt  DateTime?
  expiresAt    DateTime?
  effectivenessScore Float?

  @@index([employeeId])
}

model PerformanceReview {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  cycle       String
  score       Float
  boxLabel    String?  // matriz 9-box
  pdiStatus   String?  // PENDENTE | EM_ANDAMENTO | CONCLUIDO
  reviewedAt  DateTime

  @@index([employeeId, cycle])
}

model ClimateSurveyResponse {
  id         String   @id @default(cuid())
  cycle      String
  dimension  String
  question   String
  score      Int
  area       String?
  unitId     String?
  comment    String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([cycle, dimension])
}

// Metadados por ciclo de pesquisa (não por resposta): quantas pessoas foram
// convidadas e quantas de fato responderam. ClimateSurveyResponse guarda uma
// linha por PERGUNTA respondida (não por pessoa), então esse é o único lugar
// onde dá pra saber "quantas pessoas" participaram de cada ciclo.
model SurveyCycleMeta {
  id                String @id @default(cuid())
  cycle             String @unique
  totalInvited      Int
  totalRespondents  Int
}

model SafetyIncident {
  id          String   @id @default(cuid())
  employeeId  String?
  employee    Employee? @relation(fields: [employeeId], references: [id])
  date        DateTime
  type        String   // ACIDENTE | NEAR_MISS
  hasCAT      Boolean  @default(false)
  daysLost    Int      @default(0)
  description String?  @db.Text

  @@index([date])
}

model PayrollEntry {
  id            String   @id @default(cuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  competence    DateTime
  baseSalary    Float
  benefitsCost  Float    @default(0)
  chargesCost   Float    @default(0)
  totalCost     Float

  @@unique([employeeId, competence])
  @@index([competence])
}

model ComplianceEvent {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  date        DateTime
  type        String   // ADVERTENCIA | SUSPENSAO | PROCESSO
  reasonId    String?
  reason      Reason?  @relation(fields: [reasonId], references: [id])
  estimatedCost Float?

  @@index([date, type])
}

model RevenueEntry {
  id         String   @id @default(cuid())
  competence DateTime @unique
  amount     Float
}

// Acompanhamento do período de experiência (30/60 dias). employeeId fica nulo
// quando o nome do histórico importado não bateu com o cadastro — o registro
// ainda fica salvo, só não aparece vinculado a um colaborador específico.
model ProbationTracking {
  id            String    @id @default(cuid())
  employeeName  String
  employeeId    String?   @unique
  employee      Employee? @relation(fields: [employeeId], references: [id])
  evaluatorName String?
  day30Date     DateTime?
  day30Status   String?
  day60Date     DateTime?
  day60Status   String?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Referência de mercado salarial por cargo (benchmarking). NÃO é uma integração
// ao vivo — os valores são inseridos/atualizados manualmente a partir de pesquisas
// de mercado (ex.: Glassdoor, Indeed, Catho, Mercer), sempre com fonte e data
// de referência visíveis para o usuário.
model SalaryBenchmark {
  id             String   @id @default(cuid())
  positionId     String   @unique
  position       Position @relation(fields: [positionId], references: [id])
  region         String   @default("Fortaleza, CE")
  industry       String   @default("Indústria de Alimentos")
  marketMinSalary Float
  marketAvgSalary Float
  marketMaxSalary Float
  source         String
  referenceDate  DateTime
  updatedAt      DateTime @updatedAt
}
